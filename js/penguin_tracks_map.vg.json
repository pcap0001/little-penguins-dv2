{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 620,
    "height": 480,
    "title": "Recorded Movement of Tracked Little Penguins",
    "params": [
        {
            "name": "show237",
            "value": true
        },
        {
            "name": "show360",
            "value": true
        },
        {
            "name": "show251",
            "value": true
        },
        {
            "name": "show364",
            "value": true
        },
        {
            "name": "show250",
            "value": true
        },
        {
            "name": "show252",
            "value": true
        },
        {
            "name": "show243",
            "value": true
        },
        {
            "name": "show248",
            "value": true
        },
        {
            "name": "show366",
            "value": true
        },
        {
            "name": "show361",
            "value": true
        },
        {
            "name": "zoom_level",
            "value": 60000,
            "bind": {
                "input": "range",
                "min": 10000,
                "max": 200000,
                "step": 1000,
                "name": "Zoom: "
            }
        }
    ],
    "projection": {
        "type": "mercator",
        "center": [
            144.9,
            -38
        ],
        "scale": {
            "expr": "zoom_level"
        }
    },
    "layer": [
        {
            "data": {
                "url": "https://pcap0001.github.io/little-penguins-dv2/data/southeast_australia.json",
                "format": {
                    "type": "topojson",
                    "feature": "ne_10m_admin_0_countries"
                }
            },
            "mark": {
                "type": "geoshape",
                "fill": "#e6eef2",
                "stroke": "#9aa6ac",
                "strokeWidth": 0.5
            }
        },
        {
            "data": {
                "url": "https://pcap0001.github.io/little-penguins-dv2/data/little_penguins_tracking_clean.csv"
            },
            "transform": [
                {
                    "filter": "isValid(datum.decimalLongitude) && isValid(datum.decimalLatitude)"
                },
                {
                    "calculate": "toDate(datum.eventDate)",
                    "as": "eventDateTime"
                },
                {
                    "filter": "toNumber(datum.organismID) < 1000"
                },
                {
                    "filter": "(show237 && datum.organismID == '237') || (show360 && datum.organismID == '360') || (show251 && datum.organismID == '251') || (show364 && datum.organismID == '364') || (show250 && datum.organismID == '250') || (show252 && datum.organismID == '252') || (show243 && datum.organismID == '243') || (show248 && datum.organismID == '248') || (show366 && datum.organismID == '366') || (show361 && datum.organismID == '361')"
                }
            ],
            "mark": {
                "type": "line",
                "strokeWidth": 1.2,
                "opacity": 0.45
            },
            "encoding": {
                "longitude": {
                    "field": "decimalLongitude",
                    "type": "quantitative"
                },
                "latitude": {
                    "field": "decimalLatitude",
                    "type": "quantitative"
                },
                "detail": {
                    "field": "organismID",
                    "type": "nominal"
                },
                "color": {
                    "field": "organismID",
                    "type": "nominal",
                    "title": "Penguin ID",
                    "legend": null,
                    "scale": {
                        "domain": [
                            "237",
                            "243",
                            "248",
                            "250",
                            "251",
                            "252",
                            "360",
                            "361",
                            "364",
                            "366"
                        ],
                        "range": [
                            "#4c78a8",
                            "#f58518",
                            "#e45756",
                            "#72b7b2",
                            "#54a24b",
                            "#eeca3b",
                            "#b279a2",
                            "#ff9da6",
                            "#9d755d",
                            "#bab0ac"
                        ]
                    }
                },
                "order": {
                    "field": "eventDateTime",
                    "type": "temporal"
                }
            }
        },
        {
            "data": {
                "url": "https://pcap0001.github.io/little-penguins-dv2/data/little_penguins_tracking_clean.csv"
            },
            "transform": [
                {
                    "filter": "isValid(datum.decimalLongitude) && isValid(datum.decimalLatitude)"
                },
                {
                    "calculate": "toDate(datum.eventDate)",
                    "as": "eventDateTime"
                },
                {
                    "filter": "toNumber(datum.organismID) < 1000"
                },
                {
                    "filter": "(show237 && datum.organismID == '237') || (show360 && datum.organismID == '360') || (show251 && datum.organismID == '251') || (show364 && datum.organismID == '364') || (show250 && datum.organismID == '250') || (show252 && datum.organismID == '252') || (show243 && datum.organismID == '243') || (show248 && datum.organismID == '248') || (show366 && datum.organismID == '366') || (show361 && datum.organismID == '361')"
                }
            ],
            "mark": {
                "type": "circle",
                "size": 10,
                "opacity": 0.5
            },
            "encoding": {
                "longitude": {
                    "field": "decimalLongitude",
                    "type": "quantitative"
                },
                "latitude": {
                    "field": "decimalLatitude",
                    "type": "quantitative"
                },
                "color": {
                    "field": "organismID",
                    "type": "nominal",
                    "title": "Penguin ID",
                    "legend": null,
                    "scale": {
                        "domain": [
                            "237",
                            "243",
                            "248",
                            "250",
                            "251",
                            "252",
                            "360",
                            "361",
                            "364",
                            "366"
                        ],
                        "range": [
                            "#4c78a8",
                            "#f58518",
                            "#e45756",
                            "#72b7b2",
                            "#54a24b",
                            "#eeca3b",
                            "#b279a2",
                            "#ff9da6",
                            "#9d755d",
                            "#bab0ac"
                        ]
                    }
                },
                "tooltip": [
                    {
                        "field": "organismID",
                        "type": "nominal",
                        "title": "Penguin ID"
                    },
                    {
                        "field": "eventDateTime",
                        "type": "temporal",
                        "title": "Date and time",
                        "format": "%d %b %Y, %H:%M"
                    },
                    {
                        "field": "decimalLatitude",
                        "type": "quantitative",
                        "title": "Latitude",
                        "format": ".5f"
                    },
                    {
                        "field": "decimalLongitude",
                        "type": "quantitative",
                        "title": "Longitude",
                        "format": ".5f"
                    }
                ]
            }
        }
    ]
}