{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 450,
  "title": "Recorded Movement of Tracked Little Penguins",


  "params": [
  { "name": "show237", "value": true },
  { "name": "show360", "value": true },
  { "name": "show251", "value": true },
  { "name": "show364", "value": true },
  { "name": "show250", "value": true },
  { "name": "show252", "value": true },
  { "name": "show243", "value": true },
  { "name": "show248", "value": true },
  { "name": "show366", "value": true },
  { "name": "show361", "value": true }
],

  "projection": {
    "type": "mercator",
    "center": [144.89, -37.89],
    "scale": 30000
  },

  "layer": [
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/vega-datasets@2/data/world-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e6eef2",
        "stroke": "#9aa6ac",
        "strokeWidth": 0.5
      }
    },
    {
      "data": {
        "url": "https://pcap0001.github.io/little-penguins-dv2/data/little_penguins_tracking_clean.csv"
      },
      "transform": [
        {
          "filter": "isValid(datum.decimalLongitude) && isValid(datum.decimalLatitude)"
        },
        {
          "calculate": "toDate(datum.eventDate)",
          "as": "eventDateTime"
        },
        {
          "filter": "toNumber(datum.organismID) < 1000"
        },
        {
          "filter": "(show237 && datum.organismID == '237') || (show360 && datum.organismID == '360') || (show251 && datum.organismID == '251') || (show364 && datum.organismID == '364') || (show250 && datum.organismID == '250') || (show252 && datum.organismID == '252') || (show243 && datum.organismID == '243') || (show248 && datum.organismID == '248') || (show366 && datum.organismID == '366') || (show361 && datum.organismID == '361')"
        }
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 1.2,
        "opacity": 0.45
      },
      "encoding": {
        "longitude": {
          "field": "decimalLongitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "decimalLatitude",
          "type": "quantitative"
        },
        "detail": {
          "field": "organismID",
          "type": "nominal"
        },
        "color": {
          "field": "organismID",
          "type": "nominal",
          "title": "Penguin ID"
        },
        "order": {
          "field": "eventDateTime",
          "type": "temporal"
        }
      }
    },
    {
      "data": {
        "url": "https://pcap0001.github.io/little-penguins-dv2/data/little_penguins_tracking_clean.csv"
      },
      "transform": [
        {
          "filter": "isValid(datum.decimalLongitude) && isValid(datum.decimalLatitude)"
        },
        {
          "calculate": "toDate(datum.eventDate)",
          "as": "eventDateTime"
        },
        {
          "filter": "toNumber(datum.organismID) < 1000"
        },
        {
          "filter": "(show237 && datum.organismID == '237') || (show360 && datum.organismID == '360') || (show251 && datum.organismID == '251') || (show364 && datum.organismID == '364') || (show250 && datum.organismID == '250') || (show252 && datum.organismID == '252') || (show243 && datum.organismID == '243') || (show248 && datum.organismID == '248') || (show366 && datum.organismID == '366') || (show361 && datum.organismID == '361')"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 10,
        "opacity": 0.5
      },
      "encoding": {
        "longitude": {
          "field": "decimalLongitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "decimalLatitude",
          "type": "quantitative"
        },
        "color": {
          "field": "organismID",
          "type": "nominal",
          "title": "Penguin ID"
        },
        "tooltip": [
          {
            "field": "organismID",
            "type": "nominal",
            "title": "Penguin ID"
          },
          {
            "field": "eventDateTime",
            "type": "temporal",
            "title": "Date and time",
            "format": "%d %b %Y, %H:%M"
          },
          {
            "field": "decimalLatitude",
            "type": "quantitative",
            "title": "Latitude",
            "format": ".5f"
          },
          {
            "field": "decimalLongitude",
            "type": "quantitative",
            "title": "Longitude",
            "format": ".5f"
          }
        ]
      }
    }
  ]
}