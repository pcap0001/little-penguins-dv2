{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 750,
  "height": 480,
  "title": "Where Were Little Penguins Tracked?",
  "projection": {
    "type": "mercator",
    "center": [
      146.5,
      -38.5
    ],
    "scale": 2200
  },
  "layer": [
    {
      "data": {
        "url": "https://pcap0001.github.io/little-penguins-dv2/data/southeast_australia.json",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_0_countries"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e6eef2",
        "stroke": "#9aa6ac",
        "strokeWidth": 0.5
      }
    },
    {
      "data": {
        "url": "https://pcap0001.github.io/little-penguins-dv2/data/little_penguins_tracking_clean.csv"
      },
      "mark": {
        "type": "circle",
        "size": 10,
        "opacity": 0.2,
        "color": "#f20707"
      },
      "encoding": {
        "longitude": {
          "field": "decimalLongitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "decimalLatitude",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "organismID",
            "type": "nominal",
            "title": "Penguin ID"
          },
          {
            "field": "date",
            "type": "nominal",
            "title": "Date"
          },
          {
            "field": "decimalLatitude",
            "type": "quantitative",
            "title": "Latitude"
          },
          {
            "field": "decimalLongitude",
            "type": "quantitative",
            "title": "Longitude"
          }
        ]
      }
    }
  ]
}