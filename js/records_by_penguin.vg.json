{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 750,
  "height": 450,
  "title": "Most Tracked Little Penguins",
  "params": [
    {
      "name": "Top_N",
      "value": 10,
      "bind": {
        "input": "range",
        "min": 5,
        "max": 39,
        "step": 1,
        "name": "Number of penguins shown: "
      }
    }
  ],
  "data": {
    "url": "https://pcap0001.github.io/little-penguins-dv2/data/little_penguins_tracking_clean.csv"
  },
  "transform": [
    {
      "filter": "isValid(datum.organismID)"
    },
    {
      "calculate": "toNumber(datum.organismID)",
      "as": "penguinID_num"
    },
    {
      "filter": "datum.penguinID_num < 1000"
    },
    {
      "aggregate": [
        {
          "op": "count",
          "as": "tracking_records"
        }
      ],
      "groupby": [
        "organismID",
        "penguinID_num"
      ]
    },
    {
      "window": [
        {
          "op": "rank",
          "as": "rank"
        }
      ],
      "sort": [
        {
          "field": "tracking_records",
          "order": "descending"
        }
      ]
    },
    {
      "filter": "datum.rank <= Top_N"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "y": {
      "field": "organismID",
      "type": "nominal",
      "title": "Individual penguin ID",
      "sort": {
        "field": "tracking_records",
        "order": "descending"
      },
      "axis": {
        "labelLimit": 80
      }
    },
    "x": {
      "field": "tracking_records",
      "type": "quantitative",
      "title": "Number of tracking records",
      "axis": {
        "grid": true,
        "tickCount": 8,
        "labelExpr": "format(datum.value, ',.0f')"
      }
    },
    "color": {
      "condition": {
        "test": "datum.rank <= 10",
        "value": "#2f6f8f"
      },
      "value": "#9ab6c4"
    },
    "tooltip": [
      {
        "field": "rank",
        "type": "ordinal",
        "title": "Rank"
      },
      {
        "field": "organismID",
        "type": "nominal",
        "title": "Penguin ID"
      },
      {
        "field": "tracking_records",
        "type": "quantitative",
        "title": "Tracking records",
        "format": ","
      },
      {
        "field": "penguinID_num",
        "type": "quantitative",
        "title": "Numeric ID"
      }
    ]
  }
}