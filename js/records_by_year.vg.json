{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 500,
  "height": 300,
  "title": "Little Penguin Tracking Records by Year",
  "data": {
    "url": "/data/little_penguins_tracking_clean.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusTopLeft": 3,
    "cornerRadiusTopRight": 3
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Year",
      "sort": ["2008", "2009", "2010", "2011", "2012", "2013", "2014"],
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Number of tracking records"
    },
    "color": {
      "value": "#2f6f8f"
    },
    "tooltip": [
      {
        "field": "year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "aggregate": "count",
        "type": "quantitative",
        "title": "Records",
        "format": ","
      }
    ]
  }
}